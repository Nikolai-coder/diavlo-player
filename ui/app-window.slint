import { Button, VerticalBox, HorizontalBox } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "DIAVLO PLAYER";
    background: #E8111116;
    default-font-size: 13px;

    in property <string> track-title: "No track";
    in property <string> artist-name: "";
    in property <string> album-name: "";
    in property <string> status-text: "Stopped";
    in property <bool> is-playing: false;
    in property <bool> has-track: false;
    in property <float> position-secs: 0.0;
    in property <float> total-secs: 0.0;
    in property <float> volume: 0.8;
    in property <bool> is-muted: false;
    in property <string> position-text: "0:00";
    in property <string> duration-text: "0:00";

    callback play-pause-clicked();
    callback choose-file();
    callback seeked(float);
    callback volume-changed(float);
    callback mute-toggled();
    callback minimize-window();
    callback maximize-window();
    callback close-window();
    callback files-dropped([string]);
    callback set-as-default();

    min-width: 480px;
    min-height: 190px;
    preferred-width: 560px;
    preferred-height: 220px;

    // ── Root layout ────────────────────────────────────
    VerticalBox {
        spacing: 0px;

        // ── Title bar ──────────────────────────────────
        Rectangle {
            min-height: 32px;
            max-height: 32px;
            background: #00000000;

            HorizontalBox {
                padding-left: 14px;
                padding-right: 10px;
                padding-top: 4px;
                alignment: start;

                Text {
                    text: "DIAVLO PLAYER";
                    color: #FFFFFF;
                    font-weight: 600;
                    font-size: 11px;
                    vertical-alignment: center;
                    opacity: 0.7;
                }

                Rectangle { background: #00000000; }

                // Settings gear
                gear-btn := Rectangle {
                    width: 24px;
                    height: 24px;
                    background: #00000000;
                    border-radius: 5px;

                    ta-gear := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.set-as-default(); }
                    }

                    Text {
                        text: "⚙";
                        color: #888888;
                        font-size: 13px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    states [
                        hover when ta-gear.has-hover : {
                            background: #15FFFFFF;
                        }
                    ]
                }

                Rectangle { background: #00000000; min-width: 4px; }

                min-btn := Rectangle {
                    width: 26px;
                    height: 24px;
                    background: #00000000;
                    border-radius: 5px;

                    ta-min := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.minimize-window(); }
                    }

                    Text {
                        text: "─";
                        color: #AAAAAA;
                        font-size: 11px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    states [
                        hover when ta-min.has-hover : { background: #20FFFFFF; }
                    ]
                }

                close-btn := Rectangle {
                    width: 26px;
                    height: 24px;
                    background: #00000000;
                    border-radius: 5px;

                    ta-close := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.close-window(); }
                    }

                    Text {
                        text: "✕";
                        color: #AAAAAA;
                        font-size: 12px;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    states [
                        hover when ta-close.has-hover : { background: #CC3333; }
                    ]
                }
            }
        }

        // ── Empty state (no file) ──────────────────────
        if !root.has-track : Rectangle {
            background: #00000000;
            VerticalBox {
                spacing: 10px;
                alignment: center;
                padding-top: 10px;
                padding-bottom: 20px;

                Text {
                    text: "♫";
                    color: #FFFFFF;
                    font-size: 28px;
                    horizontal-alignment: center;
                    opacity: 0.2;
                }

                Text {
                    text: "Open an audio file";
                    color: #FFFFFF;
                    font-size: 14px;
                    font-weight: 600;
                    horizontal-alignment: center;
                }

                Text {
                    text: "WAV · FLAC · MP3 · AAC · OGG · AIFF";
                    color: #999999;
                    font-size: 10px;
                    horizontal-alignment: center;
                    opacity: 0.5;
                }

                Rectangle { min-height: 2px; }

                choose-btn := Rectangle {
                    background: #20FFFFFF;
                    border-radius: 8px;
                    width: 120px;
                    height: 30px;
                    border-width: 1px;
                    border-color: #12FFFFFF;

                    ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.choose-file(); }
                    }

                    Text {
                        text: "Choose file";
                        color: #FFFFFF;
                        font-size: 11px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    states [
                        hover when ta.has-hover : { background: #30FFFFFF; }
                    ]
                }
            }
        }

        // ── Now Playing (has track) ────────────────────
        if root.has-track : Rectangle {
            background: #00000000;
            HorizontalBox {
                spacing: 16px;
                padding-left: 16px;
                padding-right: 16px;
                padding-top: 4px;
                padding-bottom: 14px;

                // ── Cover art ───────────────────────────
                cover := Rectangle {
                    background: @linear-gradient(135deg, #2A1040 0%, #1A1A2E 50%, #162040 100%);
                    border-radius: 10px;
                    width: 90px;
                    height: 90px;
                    border-width: 1px;
                    border-color: #10FFFFFF;

                    Text {
                        text: "♫";
                        color: #FFFFFF;
                        font-size: 28px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        opacity: 0.15;
                    }
                }

                // ── Info + controls ────────────────────
                VerticalBox {
                    spacing: 4px;
                    padding-top: 2px;

                    // Track info
                    Text {
                        text: root.track-title;
                        color: #FFFFFF;
                        font-size: 14px;
                        font-weight: 600;
                        overflow: elide;
                    }

                    Text {
                        text: root.artist-name;
                        color: #CCCCCC;
                        font-size: 11px;
                        opacity: 0.7;
                        overflow: elide;
                        visible: root.artist-name != "";
                    }

                    Text {
                        text: root.album-name;
                        color: #999999;
                        font-size: 10px;
                        opacity: 0.5;
                        overflow: elide;
                        visible: root.album-name != "";
                    }

                    Rectangle { min-height: 2px; }

                    // ── Progress bar ─────────────────────
                    HorizontalBox {
                        spacing: 8px;

                        Text {
                            text: root.position-text;
                            color: #999999;
                            font-size: 9px;
                            vertical-alignment: center;
                            min-width: 30px;
                        }

                        progress-track := Rectangle {
                            background: #15FFFFFF;
                            border-radius: 2px;
                            height: 3px;

                            progress-fill := Rectangle {
                                background: #BB88FF;
                                border-radius: 2px;
                                height: 3px;
                                width: parent.width * (root.position-secs / max(root.total-secs, 1.0));
                            }
                        }

                        Text {
                            text: root.duration-text;
                            color: #999999;
                            font-size: 9px;
                            vertical-alignment: center;
                            min-width: 30px;
                        }
                    }

                    Rectangle { min-height: 4px; }

                    // ── Controls row ─────────────────────
                    HorizontalBox {
                        spacing: 10px;
                        alignment: center;

                        // Previous (decorative for now)
                        prev-btn := Rectangle {
                            width: 28px;
                            height: 28px;
                            background: #00000000;
                            border-radius: 14px;

                            ta-prev := TouchArea {
                                mouse-cursor: pointer;
                            }

                            Text {
                                text: "⏮";
                                color: #888888;
                                font-size: 13px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            states [
                                hover when ta-prev.has-hover : { background: #15FFFFFF; }
                            ]
                        }

                        // Play/Pause
                        pp-btn := Rectangle {
                            background: #FFFFFF;
                            border-radius: 16px;
                            width: 32px;
                            height: 32px;

                            ta-pp := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.play-pause-clicked(); }
                            }

                            Text {
                                text: root.is-playing ? "⏸" : "▶";
                                color: #111116;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            states [
                                hover when ta-pp.has-hover : { background: #F0F0F0; }
                            ]
                        }

                        // Next (decorative for now)
                        next-btn := Rectangle {
                            width: 28px;
                            height: 28px;
                            background: #00000000;
                            border-radius: 14px;

                            ta-next := TouchArea {
                                mouse-cursor: pointer;
                            }

                            Text {
                                text: "⏭";
                                color: #888888;
                                font-size: 13px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            states [
                                hover when ta-next.has-hover : { background: #15FFFFFF; }
                            ]
                        }

                        Rectangle { min-width: 12px; }

                        // Volume
                        mute-btn := Rectangle {
                            width: 22px;
                            height: 22px;
                            background: #00000000;
                            border-radius: 4px;

                            ta-mute := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.mute-toggled(); }
                            }

                            Text {
                                text: root.is-muted ? "🔇" : "🔊";
                                color: #999999;
                                font-size: 11px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            states [
                                hover when ta-mute.has-hover : { background: #15FFFFFF; }
                            ]
                        }

                        vol-track := Rectangle {
                            background: #15FFFFFF;
                            border-radius: 2px;
                            width: 60px;
                            height: 3px;

                            vol-fill := Rectangle {
                                background: #888888;
                                border-radius: 2px;
                                height: 3px;
                                width: parent.width * root.volume;
                            }
                        }
                    }
                }
            }
        }
    }

}
